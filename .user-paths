$env:LOCALAPPDATA\Microsoft\WinGet\Links
$env:LOCALAPPDATA\Microsoft\WindowsApps
# winget zip-portables get their dir appended to PATH once at install and other
# installers can clobber it; globs keep these pinned across version/hash changes
$env:LOCALAPPDATA\Microsoft\WinGet\Packages\Google.PlatformTools*\platform-tools
$env:LOCALAPPDATA\Microsoft\WinGet\Packages\Ninja-build.Ninja*
$env:LOCALAPPDATA\Microsoft\WinGet\Packages\Gyan.FFmpeg*\*\bin
$env:USERPROFILE\.cargo\bin
$env:LOCALAPPDATA\Programs\Microsoft VS Code
$env:LOCALAPPDATA\pnpm
$env:LOCALAPPDATA\pnpm\bin
$env:APPDATA\npm
$env:LOCALAPPDATA\Programs\OpenAI\Codex\bin
$env:USERPROFILE\winconf\bin
$env:USERPROFILE\src\news-search
$env:USERPROFILE\src\excel-to-pdf
$env:USERPROFILE\winconf\scripts
$env:ProgramFiles\Git\usr\bin
$env:ProgramFiles\AutoHotkey\v2
$env:LOCALAPPDATA\Programs\WinSCP
$env:USERPROFILE\scoop\shims
