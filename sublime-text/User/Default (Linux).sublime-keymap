  "press_command": "drag_select",
  "press_args":
  {
    "additive": true
  }
},
{
  "keys": ["ctrl+alt+s"],
  "command": "open_file",
  "args":  {
    "default": "${packages}/Default/Preferences.sublime-settings",
    "custom": "${packages}/User/Preferences.sublime-settings"
  }
},
{
  "keys": ["alt+shift+o"],
  "command": "close_other"
},
{
  "keys": ["j", "j"],
