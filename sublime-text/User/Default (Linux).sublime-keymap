  "context": [
  {
    "key": "setting.command_mode",
    "operand": false
  },
  {
    "key": "setting.is_widget",
    "operand": false
  }]
},
{
  "keys": ["alt+1"],
  "command": "toggle_side_bar"
},
{
  "keys": ["alt+o"],
